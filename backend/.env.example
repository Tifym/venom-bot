# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Database Configuration
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://venom:password@localhost:5432/venom_bot

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=random_string_32_chars

# Exchange Endpoints
BINANCE_WS_URL=wss://fstream.binance.com/ws/
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/
MEMPOOL_WS_URL=wss://mempool.space/api/v1/ws

# Environment
ENV=production # Use 'development' for verbose logging
